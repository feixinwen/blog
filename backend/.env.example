# ===== LLM 模型配置 =====
QWEN_API_KEY=your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ===== 数据库 =====
# MySQL 连接信息
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-db-password
DB_NAME=blog

# ===== JWT =====
JWT_SECRET=your-jwt-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ===== 搜索（Google Serper API）=====
SERPER_API_KEY=your-serper-api-key
SERPER_BASE_URL=https://google.serper.dev/search
SERPER_TIMEOUT_SECONDS=10
SERPER_MAX_RESULTS=5

# ===== 网页阅读（Jina Reader）=====
JINA_API_KEY=your-jina-api-key
JINA_READER_BASE_URL=https://r.jina.ai/
JINA_READER_TIMEOUT_SECONDS=20
JINA_READER_MAX_CHARS=8000

# ===== 网页阅读（HTTP 直连降级）=====
DIRECT_READER_TIMEOUT_SECONDS=20
DIRECT_READER_MAX_CHARS=8000
READER_MAX_CHARS_PER_PAGE=6000

# ===== 百度搜索（千帆 AI Search）=====
BAIDU_SEARCH_API_KEY=your-baidu-search-api-key

# ===== 运行环境 =====
APP_ENV=development
LOG_LEVEL=INFO
